document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('envelopeContainer');
    const envelope = document.getElementById('mainEnvelope');
    const openBtn = document.getElementById('openBtn');

    // ฟังก์ชันสั่งเปิด/ปิด
    function handleOpen(e) {
        if (e) e.stopPropagation();
        
        const isOpening = !container.classList.contains('open');
        container.classList.toggle('open');

        if (isOpening) {
            // เปลี่ยนข้อความบนปุ่ม
            openBtn.innerText = "🌸 กดอีกครั้งเพื่อเก็บจดหมาย 🌸";

            // หาพิกัดปล่อยหัวใจ
            const rect = envelope.getBoundingClientRect();
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            createHeartBurst(centerX, centerY);
        } else {
            openBtn.innerText = "🌸 กดตรงนี้เพื่อเปิดอ่านนะ 🌸";
        }
    }

    // ผูกเหตุการณ์ทั้งคลิกซอง และคลิกปุ่ม
    envelope.addEventListener('click', handleOpen);
    openBtn.addEventListener('click', handleOpen);

    // สร้างหัวใจพุ่งกระจาย
    function createHeartBurst(x, y) {
        const heartEmojis = ['❤️', '💖', '💗', '💕', '🌸', '✨'];
        const numHearts = 18;

        for (let i = 0; i < numHearts; i++) {
            const heart = document.createElement('div');
            heart.classList.add('heart-particle');
            heart.innerText = heartEmojis[Math.floor(Math.random() * heartEmojis.length)];

            const angle = (i / numHearts) * 360 + (Math.random() * 20 - 10);
            const distance = Math.random() * 120 + 60;
            const tx = Math.cos(angle * Math.PI / 180) * distance + 'px';
            const ty = Math.sin(angle * Math.PI / 180) * distance + 'px';
            const rot = (Math.random() * 360) + 'deg';

            heart.style.left = x + 'px';
            heart.style.top = y + 'px';
            heart.style.setProperty('--tx', tx);
            heart.style.setProperty('--ty', ty);
            heart.style.setProperty('--rot', rot);

            document.body.appendChild(heart);

            setTimeout(() => {
                heart.remove();
            }, 1200);
        }
    }

    // สร้างซากุระร่วง
    const sakuraContainer = document.getElementById('sakura-container');
    const sakuraEmojis = ['🌸', '🌺', '✨', '🌸', '💖'];
    for (let i = 0; i < 20; i++) {
        const petal = document.createElement('div');
        petal.classList.add('sakura');
        petal.innerText = sakuraEmojis[Math.floor(Math.random() * sakuraEmojis.length)];
        petal.style.left = Math.random() * 100 + 'vw';
        petal.style.animationDuration = (Math.random() * 5 + 5) + 's';
        petal.style.animationDelay = (Math.random() * 5) + 's';
        petal.style.fontSize = (Math.random() * 0.8 + 1) + 'rem';
        sakuraContainer.appendChild(petal);
    }
});
document.addEventListener('DOMContentLoaded', () => {
    const checkbox = document.getElementById('toggle-letter');
    const label = document.getElementById('letterLabel');

    // ดึงไฟล์เสียงเอฟเฟกต์ป๊อปน่ารักๆ จาก CDN โดยตรง
    const popSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2571/2571-preview.mp3');
    popSound.load(); // โหลดเสียงมารอไว้ในหน่วยความจำ

    function playSound() {
        if (!checkbox.checked) {
            popSound.currentTime = 0; // เล่นใหม่ตั้งแต่ต้น
            popSound.play().catch(error => {
                console.log("Audio play error:", error);
            });
        }
    }

    // ปลดล็อกการเล่นเสียงบน iPad/iPhone เมื่อมีการแตะหน้าจอ
    label.addEventListener('touchstart', playSound, { passive: true });
    label.addEventListener('click', playSound);
});
